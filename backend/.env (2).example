# ── Base de données ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/revex_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revex_db
DB_USER=postgres
DB_PASSWORD=your_password

# ── Auth ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_32_char_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Serveur ──────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://revex.ma

# ── Upload ───────────────────────────────────────────
MAX_FILE_SIZE=5242880

# ── Cloudinary (images) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Backend URL (pour les URLs d'images) ─────────────
BACKEND_URL=https://api.revex.ma
