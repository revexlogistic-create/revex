# ============================================================
# REVEX BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revex_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=revex_jwt_super_secret_change_this_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=revex_refresh_super_secret_change_this_in_production_2024
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880   # 5MB en bytes

# Email (optionnel - pour notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@revex.ma
EMAIL_PASS=your_email_password

# Stripe (optionnel - paiement simulé en dev)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary (optionnel - upload images cloud)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
